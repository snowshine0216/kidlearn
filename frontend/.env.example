# Get your key at platform.minimax.io → API Keys
# Copy this file to .env.local  (never commit .env.local)
#
# Works for BOTH local dev (npm run dev) and production (Vercel).
# The key is NOT exposed to the browser — it lives server-side only.
MINIMAX_API_KEY=your-minimax-key-here

# Client-visible hint that the server key is configured.
# Set to "true" once you've added MINIMAX_API_KEY above.
# This hides the "API key not configured" banner in the browser.
VITE_MINIMAX_API_KEY_HINT=true
